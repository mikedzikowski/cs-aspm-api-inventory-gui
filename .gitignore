# =============================================================================
# ASPM API Query - Root .gitignore
# =============================================================================
# This file prevents sensitive and generated files from being committed
# =============================================================================

# Environment Variables - NEVER COMMIT THESE
.env
.env.local
.env.production
.env.development
.env.test
*.env
!.env.example

# Internal Documentation
.private/

# Claude Code Settings (contains command history with credentials)
.claude/

# Backend Python
backend/__pycache__/
backend/**/__pycache__/
backend/*.py[cod]
backend/**/*.py[cod]
backend/.pytest_cache/
backend/htmlcov/
backend/.coverage
backend/venv/
backend/env/
backend/ENV/
backend/*.log

# Frontend Node
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
frontend/*.log
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
*.log
logs/
*.log.*

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Docker
.dockerignore

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*~

# Build outputs
dist/
build/
*.egg-info/

# Test outputs
.pytest_cache/
.coverage
htmlcov/
coverage/

# Documentation builds (if using Sphinx or similar)
docs/_build/
docs/.doctrees/

# Certificates and Keys (just in case)
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx

# Database files (if any are added later)
*.db
*.sqlite
*.sqlite3

# Backup files
*.backup
*.bak

# Cloud deployment artifacts (if needed)
.terraform/
*.tfstate
*.tfstate.*

# Performance Analysis Documents (generated, not source code)
PERFORMANCE_ANALYSIS.md
OPTIMIZATION_CODE_EXAMPLES.md
PERFORMANCE_QUICK_REFERENCE.md
PERFORMANCE_ANALYSIS_INDEX.md

# Cookie files (temporary authentication files)
*.txt
cookies*.txt

# Keep these directories but ignore contents
!backend/app/
!frontend/src/
